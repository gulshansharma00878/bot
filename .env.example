# ============================================
# DEX Perpetual Futures Trading Bot - Config
# ============================================

# --- Wallet ---
PRIVATE_KEY=your_private_key_here
WALLET_ADDRESS=0xYourWalletAddress

# --- Network RPCs (Ethereum L2) ---
ARBITRUM_RPC=https://arb1.arbitrum.io/rpc
OPTIMISM_RPC=https://mainnet.optimism.io
BASE_RPC=https://mainnet.base.org

# --- Default Network ---
DEFAULT_NETWORK=arbitrum

# --- Trading Mode ---
# live | paper
TRADING_MODE=paper

# --- GMX V2 Contracts (Arbitrum) ---
GMX_ROUTER=0x7C68C7866A64FA2160F78EEaE12217FFbf871fa8
GMX_READER=0xf60becbba223EEA9495Da3f606753867eC10d139
GMX_DATASTORE=0xFD70de6b91282D8017aA4E741e9Ae325CAb992d8
GMX_EXCHANGE_ROUTER=0x7C68C7866A64FA2160F78EEaE12217FFbf871fa8

# --- Price Feed ---
# coingecko | chainlink | gmx
PRICE_FEED_SOURCE=coingecko

# --- Strategy ---
# trend_following | mean_reversion | funding_arbitrage
DEFAULT_STRATEGY=trend_following

# --- Risk Parameters ---
MAX_RISK_PER_TRADE=0.02
MAX_DAILY_LOSS=0.05
MAX_LEVERAGE=10
DEFAULT_LEVERAGE=3
STOP_LOSS_PERCENT=0.03
TAKE_PROFIT_PERCENT=0.06
TRAILING_STOP_PERCENT=0.02

# --- Capital ---
TRADING_CAPITAL_USD=10000

# --- Notifications ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook

# --- Logging ---
LOG_LEVEL=info

# --- Backtest ---
BACKTEST_START_DATE=2025-04-14
BACKTEST_END_DATE=2026-04-14
BACKTEST_INITIAL_CAPITAL=10000
