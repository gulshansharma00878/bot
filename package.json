{
  "name": "dex-trade",
  "version": "1.0.0",
  "description": "DEX Perpetual Futures Trading Bot for Ethereum L2",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "rebuild": "npm run clean && npm run build",
    "start": "ts-node -r tsconfig-paths/register src/index.ts",
    "start:live": "NODE_ENV=production ts-node -r tsconfig-paths/register src/index.ts --mode live",
    "start:paper": "ts-node -r tsconfig-paths/register src/index.ts --mode paper",
    "start:dist": "node dist/index.js",
    "start:dist:live": "NODE_ENV=production node dist/index.js --mode live",
    "backtest": "ts-node -r tsconfig-paths/register src/backtest/runner.ts",
    "typecheck": "tsc --noEmit",
    "logs": "tail -f logs/*.log",
    "test": "echo \"No tests yet\" && exit 0"
  },
  "keywords": [
    "dex",
    "trading",
    "bot",
    "perpetual",
    "futures",
    "l2"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "axios": "^1.15.0",
    "csv-writer": "^1.6.0",
    "dotenv": "^17.4.2",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "node-cache": "^5.1.2",
    "technicalindicators": "^3.1.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.2"
  }
}
